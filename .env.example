# VerifAI Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file with real secrets.

# ─── App ──────────────────────────────────────────────────────────
APP_NAME=VerifAI
ENVIRONMENT=development          # development | production
DEBUG=False                      # Keep False in production

# ─── Database ─────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://verifai_user:your_db_password@localhost:5432/verifai_db

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT / Security ───────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# ─── Email (Gmail SMTP) ───────────────────────────────────────────
# Use a Gmail App Password (NOT your account password).
# Enable 2FA on your Google account, then generate an App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# ─── Support ──────────────────────────────────────────────────────
SUPPORT_EMAIL=support@verifai.app
SUPPORT_PHONE=+91-XXXXXXXXXX

# ─── App URLs ─────────────────────────────────────────────────────
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ─── Fraud Detection Thresholds ───────────────────────────────────
FRAUD_HIGH_RISK_THRESHOLD=0.80
FRAUD_MEDIUM_RISK_THRESHOLD=0.50

# ─── ML Model Paths ───────────────────────────────────────────────
ML_MODEL_PATH=app/ml/models/xgboost_fraud_model.pkl
SCALER_PATH=app/ml/models/scaler.pkl

# ─── WhatsApp Business API (optional) ────────────────────────────
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
